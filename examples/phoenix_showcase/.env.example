# Copy to .env and adjust, then: `set -a; source .env; set +a` before mix phx.server

# Base URL of the running KilnCMS instance.
KILN_API_URL=http://localhost:4000

# Optional: a `kiln_…` API key (mint one at /editor/api-keys). Sent as a bearer
# token so the app can read beyond public content. Leave unset for public-only.
# KILN_API_KEY=kiln_xxx_yy

# Default content locale to request from the delivery API.
KILN_LOCALE=en
