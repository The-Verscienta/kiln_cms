---
import Base from "../../layouts/Base.astro";
import { discoverContent, fetchArtifact, type Document } from "../../lib/kiln";
import { renderBlocks } from "../../lib/render";

// Static generation: one page per published document discovered in the sitemap.
// The artifact is fetched here so each route ships as plain pre-rendered HTML.
export async function getStaticPaths() {
  const refs = await discoverContent();

  const pages = await Promise.all(
    refs.map(async (ref) => {
      const doc = await fetchArtifact(ref);
      if (!doc) return null;
      return {
        params: { type: ref.type, slug: ref.slug },
        props: { doc },
      };
    }),
  );

  return pages.filter((page): page is NonNullable<typeof page> => page !== null);
}

interface Props {
  doc: Document;
}
const { doc } = Astro.props as Props;
const html = renderBlocks(doc.blocks);
---

<Base title={doc.title}>
  <article>
    <h1>{doc.title}</h1>
    <Fragment set:html={html} />
  </article>
  <p style="margin-top:2rem"><a href="/">← Back to all content</a></p>
</Base>
