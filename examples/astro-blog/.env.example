# Base URL of the running KilnCMS instance the site fetches content from.
# Defaults to http://localhost:4000 if unset.
KILN_API_URL=http://localhost:4000

# Optional: the locale to build. KilnCMS serves the default locale ("en") at the
# bare slug; other locales are published under their own slugs/prefixes.
KILN_LOCALE=en
