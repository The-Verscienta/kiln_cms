{
  "name": "Quote request",
  "description": "Project details, budget and timeline.",
  "form": {
    "success_message": "Request received — we'll send a quote shortly.",
    "submit_label": "Request quote"
  },
  "fields": [
    { "name": "company", "label": "Company", "field_type": "string", "width": "half" },
    {
      "name": "full_name",
      "label": "Your name",
      "field_type": "string",
      "required": true,
      "width": "half"
    },
    {
      "name": "email",
      "label": "Email",
      "field_type": "email",
      "required": true,
      "width": "half"
    },
    { "name": "phone", "label": "Phone", "field_type": "phone", "width": "half" },
    {
      "name": "budget",
      "label": "Budget",
      "field_type": "select",
      "width": "half",
      "options": ["Under $1,000", "$1,000–$5,000", "$5,000–$20,000", "Over $20,000"]
    },
    {
      "name": "timeline",
      "label": "Timeline",
      "field_type": "select",
      "width": "half",
      "options": ["As soon as possible", "1–3 months", "3+ months"]
    },
    {
      "name": "details",
      "label": "Project details",
      "field_type": "text",
      "required": true
    }
  ]
}
