# Copy to .env and adjust. Used by docker-compose and (optionally) local dev.

# --- Postgres (required) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kiln_cms_dev
POSTGRES_PORT=5432

# Phoenix/Ecto connection (used in prod via runtime.exs).
DATABASE_URL=ecto://postgres:postgres@localhost:5432/kiln_cms_dev

# --- Phoenix (required in prod) ---
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=
PHX_HOST=localhost
PORT=4000

# --- Dragonfly (optional — multi-node shared cache only, profile: cache) ---
DRAGONFLY_PORT=6379
# REDIS_URL=redis://localhost:6379

# --- Meilisearch (optional — profile: search) ---
MEILI_PORT=7700
MEILI_MASTER_KEY=masterKeyChangeMe

# --- MinIO / S3 (optional — profile: storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- LLM (optional — AI assist, Stretch phase) ---
# AI_API_KEY=
