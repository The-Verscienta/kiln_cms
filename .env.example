# Copy to .env and adjust. Used by docker-compose and (optionally) local dev.

# --- Postgres (required) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kiln_cms_dev
POSTGRES_PORT=5432

# Phoenix/Ecto connection (used in prod via runtime.exs).
DATABASE_URL=ecto://postgres:postgres@localhost:5432/kiln_cms_dev

# --- Phoenix (required in prod) ---
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=
PHX_HOST=localhost
PORT=4000

# --- Dragonfly (optional — multi-node shared cache only, profile: cache) ---
DRAGONFLY_PORT=6379
# REDIS_URL=redis://localhost:6379

# --- Meilisearch (optional — profile: search) ---
MEILI_PORT=7700
MEILI_MASTER_KEY=masterKeyChangeMe

# --- MinIO / S3 (optional — profile: storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Object storage adapter (prod, runtime.exs): set S3_BUCKET to switch media
# blobs from local disk to the S3-compatible adapter. Works with AWS S3,
# Cloudflare R2, Backblaze B2, Wasabi, MinIO, etc.
# S3_BUCKET=kiln-media
# S3_PUBLIC_BASE_URL=https://cdn.example.com          # key is appended; include the bucket path
# AWS_ACCESS_KEY_ID=...                                 # provider access key (MinIO: root user above)
# AWS_SECRET_ACCESS_KEY=...                             # provider secret (MinIO: root password above)
# AWS_REGION=us-east-1                                  # R2: "auto"; B2/Wasabi/AWS: a real region
# S3_ACL=public_read                                    # optional; only if the bucket uses per-object ACLs
#
# Non-AWS providers also need the endpoint (S3_ENDPOINT_SCHEME defaults to https://,
# S3_ENDPOINT_PORT to 443). Pick one:
# MinIO (local dev):   S3_ENDPOINT_HOST=localhost  S3_ENDPOINT_SCHEME=http://  S3_ENDPOINT_PORT=9000
# Cloudflare R2:       S3_ENDPOINT_HOST=<accountid>.r2.cloudflarestorage.com
# Backblaze B2:        S3_ENDPOINT_HOST=s3.us-west-002.backblazeb2.com
# Wasabi:              S3_ENDPOINT_HOST=s3.us-east-1.wasabisys.com

# --- LLM (optional — AI assist, Stretch phase) ---
# AI_API_KEY=
