{require_min_otp_vsn,"23"}.
{minimum_otp_vsn,"23"}.
{cover_enabled,true}.
{eunit_opts,[verbose,{report,{eunit_surefire,[{dir,"."}]}}]}.
{edoc_opts,[{preprocess,true}]}.
{dialyzer_opts,[{warnings,[no_return,no_unused,no_improper_lists,no_fun_app,
                           no_match,no_opaque,no_fail_call,error_handling,
                           race_conditions,behaviours,unmatched_returns]}]}.
{overrides,[]}.
