# Sobelow config (read by `mix sobelow --config`, run in `mix precommit`/CI).
# exit: "low" makes the scan return a non-zero status on any finding at or
# above Low confidence, so it fails the build.
[
  exit: "low",
  threshold: :low,
  verbose: false,
  # Config.CSP: the Content-Security-Policy is set dynamically (nonce-based)
  # in the router's put_csp/put_dev_csp plugs, which Sobelow's static check
  # can't follow. The header is present on every browser response and was
  # verified in-browser, so this is a false positive.
  ignore: ["Config.CSP"],
  ignore_files: []
]